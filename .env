# 吃了么 (chileme) 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== 美团联盟 CPS 配置 ====================
# 方案 1: 订单侠 API（推荐，个人可用）
# 注册地址：https://www.dingdanxia.com/
# 文档：https://www.dingdanxia.com/doc/195/173
VITE_DINGDANXIA_APPKEY=your_dingdanxia_appkey_here
VITE_DINGDANXIA_SECRET=your_dingdanxia_secret_here
VITE_DINGDANXIA_POSITION_ID=your_position_id

# 方案 2: 美团官方 API（需企业资质）
VITE_MEITUAN_APPKEY=1b2a6f8c202ca60b6ec6fddd93fd7397
VITE_MEITUAN_SECRET=ce89fdb7326d30a15b2fdc400e3835cb
VITE_MEITUAN_POSITION_ID=shipinwaimai
VITE_MEITUAN_CHANNEL_ID=473920
VITE_MEITUAN_MINI_APP_ID=wxde8ac0a21135c0

# 启用 CPS 功能
VITE_CPS_ENABLED=true

# 使用哪个 API 提供商：dingdanxia | meituan
VITE_CPS_PROVIDER=dingdanxia

# ==================== 应用配置 ====================
VITE_APP_NAME=吃了么
VITE_APP_VERSION=1.5.0
